# Copy to .env for LOCAL testing only. On GitHub, set these as Actions secrets/vars.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# AI provider: "gemini" (default) or "groq". Only the chosen provider's key is needed.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# Optional Groq alternative (free tier). Set AI_PROVIDER=groq to use it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
