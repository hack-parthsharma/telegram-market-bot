# Copy to .env for LOCAL testing only. On GitHub, set these as Actions secrets/vars.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# AI via OpenRouter — one key, multiple free models tried in order (fallback chain).
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional: override the model fallback chain (comma-separated, order = priority).
# Leave unset to use the built-in default chain of 4 free models.
OPENROUTER_MODELS=
